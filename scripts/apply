#!/usr/bin/env bash
set -euo pipefail

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
target_host="${1:-$(hostname -s)}"

case "$(uname -s)" in
  Darwin)
    exec sudo darwin-rebuild switch --flake "${repo_dir}#${target_host}"
    ;;
  Linux)
    exec sudo nixos-rebuild switch --flake "${repo_dir}#${target_host}"
    ;;
  *)
    echo "Unsupported operating system: $(uname -s)" >&2
    exit 1
    ;;
esac
